#!/bin/bash
# pre-commit hook for Mission Control
# Detects changes to AI tool configuration files

AI_FILES_PATTERN="(\.cursorrules|CLAUDE\.md|AGENTS\.md|\.claude/|\.cursor/|\.github/workflows/)"

echo "Checking for AI tool configuration changes..."

# Get list of changed files
CHANGED_FILES=$(git diff --cached --name-only | grep -E "$AI_FILES_PATTERN" || true)

if [ -n "$CHANGED_FILES" ]; then
    echo "AI tool configuration files detected:"
    echo "$CHANGED_FILES"
    echo ""
    echo "These files will be tracked for review after commit."
    # Create a marker file for post-commit hook
    echo "$CHANGED_FILES" > .mc/git_hooks/pending_ai_changes.txt
    mkdir -p .mc/git_hooks
else
    echo "No AI tool configuration changes detected."
    rm -f .mc/git_hooks/pending_ai_changes.txt 2>/dev/null || true
fi

exit 0
